# Django Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

DEBUG=False
SECRET_KEY={{ django_secret_key | default('changeme-use-vault') }}
ALLOWED_HOSTS={{ allowed_hosts | default('*') }}

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME={{ db_name | default('agileflow') }}
DB_USER={{ db_user | default('agileflow') }}
DB_PASSWORD={{ db_password }}
DB_HOST={{ db_host | default('postgres') }}
DB_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://{{ redis_host | default('redis') }}:6379/0
CELERY_RESULT_BACKEND=redis://{{ redis_host | default('redis') }}:6379/0

# AI Service
AI_SERVICE_URL=http://fastapi_ai:8001

# Security
CSRF_TRUSTED_ORIGINS={{ csrf_trusted_origins | default('https://' + inventory_hostname) }}
